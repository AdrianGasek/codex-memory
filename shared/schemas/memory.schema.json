{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-mem.local/schemas/memory.schema.json",
  "title": "CodexMemMemoryEntry",
  "type": "object",
  "required": ["type", "title"],
  "properties": {
    "id": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["fact", "decision", "bug", "solution", "pattern"]
    },
    "title": { "type": "string", "minLength": 1, "maxLength": 160 },
    "context": { "type": "string", "default": "" },
    "resolution": { "type": "string", "default": "" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.75 },
    "importance": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.5 },
    "pinned": { "type": "boolean", "default": false },
    "file_paths": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "source": { "type": "string", "default": "manual" },
    "project": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "status": {
      "type": "string",
      "enum": ["active", "superseded"],
      "default": "active"
    },
    "conflict_ids": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "superseded_by": { "type": ["string", "null"], "default": null },
    "retrieved_count": { "type": "integer", "minimum": 0, "default": 0 },
    "injected_count": { "type": "integer", "minimum": 0, "default": 0 },
    "last_used_timestamp": { "type": ["string", "null"], "format": "date-time", "default": null }
  },
  "additionalProperties": false
}
