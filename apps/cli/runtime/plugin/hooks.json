{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "codex-mem hook session-start",
            "timeout": 5,
            "statusMessage": "Loading Codex-Mem context"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "codex-mem hook user-prompt",
            "timeout": 5,
            "statusMessage": "Retrieving Codex-Mem context"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "codex-mem hook stop",
            "timeout": 5,
            "statusMessage": "Codex-Mem capture pass"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "codex-mem hook post-tool-use",
            "timeout": 5,
            "statusMessage": "Codex-Mem tool-result capture"
          }
        ]
      }
    ]
  }
}
