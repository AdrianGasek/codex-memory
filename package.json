{
  "name": "codex-mem",
  "version": "1.0.8",
  "private": true,
  "type": "module",
  "description": "Local persistent memory for Codex agents that captures, searches, and reuses project knowledge.",
  "homepage": "https://github.com/AdrianGasek/codex-memory#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AdrianGasek/codex-memory.git"
  },
  "bugs": {
    "url": "https://github.com/AdrianGasek/codex-memory/issues"
  },
  "keywords": [
    "codex",
    "codex-memory",
    "ai-agent",
    "agent-memory",
    "persistent-memory",
    "mcp",
    "mcp-server",
    "codex-plugin",
    "developer-tools",
    "local-first",
    "sqlite",
    "cli",
    "typescript"
  ],
  "author": "AdrianGasek",
  "license": "MIT",
  "files": [
    "README.md",
    "LICENSE"
  ],
  "workspaces": [
    "apps/cli",
    "apps/mcp-server"
  ],
  "scripts": {
    "build": "bun run build:cli && bun run build:mcp && node infra/scripts/stage-cli-runtime.mjs",
    "build:cli": "tsc -p apps/cli/tsconfig.json",
    "build:mcp": "tsc -p apps/mcp-server/tsconfig.json",
    "cli:test": "bun --cwd apps/cli test",
    "pack": "bun run build && node infra/scripts/pack-packages.mjs",
    "pack:cli": "bun run build && node infra/scripts/pack-packages.mjs apps/cli",
    "pack:mcp": "bun run build:mcp && node infra/scripts/pack-packages.mjs apps/mcp-server",
    "pack:smoke": "bun run pack:cli && node infra/scripts/npm-pack-smoke.mjs",
    "smoke:npx-install": "bun run pack:cli && node infra/scripts/smoke-npx-install.mjs",
    "release:check": "node infra/scripts/check-publishable-package.mjs apps/cli/package.json",
    "release:check:confirmed": "node infra/scripts/check-publishable-confirmed.mjs apps/cli/package.json",
    "prepublishOnly": "node infra/scripts/refuse-root-publish.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -p apps/cli/tsconfig.json --noEmit && tsc -p apps/mcp-server/tsconfig.json --noEmit",
    "api:test": "uv run --project apps/api pytest apps/api/tests",
    "api:dev": "uv run --project apps/api uvicorn app.main:app --reload --host 127.0.0.1 --port 8000",
    "mcp:dev": "bun run apps/mcp-server/src/server.ts",
    "cli": "bun run apps/cli/src/index.ts"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  }
}
