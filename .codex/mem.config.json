{
  "project": "codex-brain",
  "inject_limit": 5,
  "token_budget": 1200,
  "vector_backend": "local",
  "embeddings": {
    "provider": "local",
    "model": "local-hash"
  },
  "summarization": {
    "provider": "local",
    "model": "extractive"
  },
  "capture": {
    "mode": "active",
    "sensitivity": "standard",
    "ignore_paths": ["data/db", "data/vectors", "node_modules", "dist", "logs", "*.log", "vendor"],
    "no_store_tags": ["private", "no-store"],
    "no_store_paths": ["secrets", "private", "*.pem", "*.key"]
  },
  "debug": {
    "verbose": false,
    "capture_log_enabled": false,
    "capture_log": ".codex/CAPTURE_DEBUG.jsonl"
  },
  "sync": {
    "enabled": false,
    "scope": "local"
  },
  "security": {
    "db_encryption_enabled": false
  },
  "team": {
    "backend": "local"
  }
}
