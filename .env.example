CODEX_MEM_API_URL=http://127.0.0.1:8000
CODEX_MEM_DATA_DIR=./data
CODEX_MEM_DB_PATH=./data/db/codex-mem.sqlite3
CODEX_MEM_PROJECT=default
CODEX_MEM_INJECT_LIMIT=5
CODEX_MEM_TOKEN_BUDGET=1200
CODEX_MEM_VECTOR_BACKEND=local
CODEX_MEM_CHROMA_URL=http://127.0.0.1:8000
CODEX_MEM_PGVECTOR_DSN=
CODEX_MEM_MODE=active
CODEX_MEM_CAPTURE_MODE=active
CODEX_MEM_APPROVAL_QUEUE=.codex/PENDING_MEMORY.jsonl
CODEX_MEM_HOOKS_ENABLED=true
CODEX_MEM_DISABLED_HOOKS=
CODEX_MEM_DEBUG_VERBOSE=false
CODEX_MEM_CAPTURE_DEBUG_LOG_ENABLED=false
CODEX_MEM_CAPTURE_DEBUG_LOG=.codex/CAPTURE_DEBUG.jsonl
CODEX_MEM_SYNC_ENABLED=false
CODEX_MEM_SYNC_SCOPE=local
CODEX_MEM_DB_ENCRYPTION_ENABLED=false
CODEX_MEM_DB_ENCRYPTION_KEY=
CODEX_MEM_TEAM_BACKEND=local
CODEX_MEM_TEAM_ID=default
CODEX_MEM_TEAM_ROLE=reader
CODEX_MEM_TEAM_WRITE_ENABLED=false
CODEX_MEM_SHARED_WRITE_ENABLED=false
CODEX_MEM_MCP_TRANSPORT=stdio
CODEX_MEM_MCP_HOST=127.0.0.1
CODEX_MEM_MCP_PORT=3333

# Local profile:
# CODEX_MEM_PROJECT=local-dev
# CODEX_MEM_VECTOR_BACKEND=local
# CODEX_MEM_SYNC_ENABLED=false

# Dev profile with verbose diagnostics:
# CODEX_MEM_PROJECT=codex-mem-dev
# CODEX_MEM_MODE=debug
# CODEX_MEM_DEBUG_VERBOSE=true
# CODEX_MEM_CAPTURE_DEBUG_LOG_ENABLED=true

# Team namespace profile:
# CODEX_MEM_PROJECT=team-workspace
# CODEX_MEM_TEAM_ID=example-team
# CODEX_MEM_TEAM_ROLE=writer
# CODEX_MEM_TEAM_WRITE_ENABLED=true
# CODEX_MEM_SHARED_WRITE_ENABLED=true
